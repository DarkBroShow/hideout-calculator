# =====================
# Postgres
# =====================

# Имя пользователя БД
POSTGRES_USER=hideout

# Пароль пользователя БД
POSTGRES_PASSWORD=change_me

# Имя базы данных
POSTGRES_DB=hideout

# Хост БД (в docker-compose — имя сервиса)
POSTGRES_HOST=hideout-db

# Порт БД внутри docker-сети
POSTGRES_PORT=5432


# Полный URL подключения к базе (используется backend’ом)
# Формат: postgres://<user>:<password>@<host>:<port>/<db>
DATABASE_URL=postgres://hideout:change_me@hideout-db:5432/hideout


# =====================
# Backend
# =====================

# Внутренний порт backend-контейнера
BACKEND_PORT=4000

# Внешний порт backend’а на хосте
BACKEND_PORT_EXTERNAL=14000


# =====================
# Stalcraft API
# =====================
# Эти значения ОБЯЗАТЕЛЬНО заменить на реальные из кабинета Stalcraft:
# Регистрация и получение данных: https://eapi.stalcraft.net/registration.html

STALCRAFT_CLIENT_ID=your_client_id_here
STALCRAFT_CLIENT_SECRET=your_client_secret_here
STALCRAFT_REGION=ru


# =====================
# Frontend
# =====================

# URL backend API, на который ходит фронтенд
# При запуске через reverse-proxy — обычно https://hideout.broshow.ru/api
VITE_API_URL=http://localhost:14000

# Внешний порт фронтенда на хосте
FRONTEND_PORT_EXTERNAL=8080